<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Meta-package: no compiled output of its own. -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <!--
    Umbrella package. Installing Apigen.Hetzner pulls in all three sub-clients;
    each sub-client retains its own auth context (Bearer or Basic). Auth tokens
    are NOT shared across Cloud / Api / Robot — they come from different
    Hetzner consoles entirely.
  -->
  <ItemGroup>
    <ProjectReference Include="../Apigen.Hetzner.Cloud/Apigen.Hetzner.Cloud.csproj" />
    <ProjectReference Include="../Apigen.Hetzner.Api/Apigen.Hetzner.Api.csproj" />
    <ProjectReference Include="../Apigen.Hetzner.Robot/Apigen.Hetzner.Robot.csproj" />
  </ItemGroup>

</Project>
